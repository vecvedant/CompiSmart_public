# Copy to .env and fill in. Do NOT commit .env.

# Apify — scrapes YouTube + Instagram metadata, comments, media URLs.
# Get from https://console.apify.com/account/integrations
APIFY_TOKEN=

# Deepgram — speech-to-text for Instagram audio.
# Get from https://console.deepgram.com/
DEEPGRAM_API_KEY=

# Google Gemini — the chat brain.
# Get from https://aistudio.google.com/app/apikey
# Either name works (GOOGLE_API_KEY or GEMINI_API_KEY).
GOOGLE_API_KEY=

# Qdrant Cloud — vector database (1 GB free forever).
# Sign up at https://cloud.qdrant.io/, create a free cluster.
QDRANT_URL=
QDRANT_API_KEY=

# Supabase — structured store (niches, feed cache, assets, chat history, drafts).
# Sign up at https://supabase.com/ (free tier 500MB DB). Create a project,
# run backend/supabase/schema.sql in the SQL editor, then grab:
#   SUPABASE_URL    = Project Settings → API → Project URL
#   SUPABASE_SERVICE_KEY = Project Settings → API → service_role secret
# Service role is fine here because the demo is session-scoped (no RLS).
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# NewsAPI — top-headlines feed source per niche.
# Get from https://newsapi.org/account (free tier: 100 req/day).
NEWSAPI_KEY=

# Optional: override the embedding model (default BAAI/bge-small-en-v1.5).
# EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Optional: override the Gemini model (default gemini-2.5-flash-lite).
# GEMINI_MODEL=gemini-2.5-flash-lite
